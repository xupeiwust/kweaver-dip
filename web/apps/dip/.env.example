# 后端服务地址（开发调试常用）。
# 是否必填：建议填写；未配置时，依赖本地/默认请求路径行为。
# 示例：https://your-backend-origin
DEBUG_ORIGIN=

# 本地调试时可选的访问令牌。
# 是否必填：否（可为空）。
# 示例：eyJhbGciOi...
PUBLIC_TOKEN=

# 与 PUBLIC_TOKEN 配套的刷新令牌。
# 是否必填：否（可为空）。
# 示例：eyJhbGciOi...
PUBLIC_REFRESH_TOKEN=

# 启用模块列表（按约定格式填写）。
# 是否必填：否（留空表示使用默认模块可见策略）。
# 示例：moduleA,moduleB
PUBLIC_ENABLED_MODULES=

# 是否跳过认证流程（仅建议本地联调使用）。
# 是否必填：否（默认 false）。
# 可选值：true / false
PUBLIC_SKIP_AUTH=false

# 是否启用管理员视角（仅影响前端展示权限相关逻辑）。
# 是否必填：否（默认 false）。
# 可选值：true / false
PUBLIC_IS_ADMIN=false
