PORT=3000

# 生产环境请避免使用 .env 文件，改为使用环境变量或其他安全的配置管理方式

DB_HOST=                                # MariaDB 主机地址
DB_PORT=                                # MariaDB 端口
DB_USER=                                # MariaDB 用户名
DB_PASSWORD=                            # MariaDB 密码
DB_NAME=                                # MariaDB 数据库名

KWEAVER_BASE_URL=                       # 可选，KWeaver 服务地址
KWEAVER_TOKEN=                          # 可选，KWeaver Token

OAUTH_MOCK_USER_ID=                     # 可选，用于开发环境的 OAuth 模拟用户 ID
KWEAVER_HYDRA_ADMIN_URL=                # 可选，Hydra 管理后台地址，用于 token 内省
